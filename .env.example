# Local Docker Postgres:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/outlet_validator
#
# Supabase project: outlet-validator (kgoexrabyvldygdudnol)
# Use the transaction/session pooler URL from Supabase Database > Connect > Pooler settings.
# Copy the exact pooler user and host shown there; do not infer them from the project ref.
# DATABASE_URL=postgresql://<POOLER_USER>:<DB_PASSWORD>@<POOLER_HOST>:6543/postgres?sslmode=require
#
# Netlify production deploys need DATABASE_URL available to both Builds and Functions.
PORT=4000
VITE_API_BASE_URL=http://localhost:4000
JWT_SECRET=change-me-in-development
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin
DEMO_MODE=false
